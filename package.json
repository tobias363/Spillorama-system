{
  "name": "spillorama-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/backend",
    "apps/admin-web"
  ],
  "scripts": {
    "dev": "npm --prefix apps/backend run dev",
    "dev:admin": "npm -w @spillorama/admin-web run dev",
    "dev:admin:prod": "npm -w @spillorama/admin-web run dev:prod-backend",
    "dev:games": "npm -w @spillorama/game-client run dev",
    "dev:all": "node scripts/dev/start-all.mjs",
    "dev:nuke": "bash scripts/dev/nuke-restart.sh",
    "dev:sync": "bash scripts/dev/sync-from-main.sh",
    "dev:seed": "node scripts/dev/seed-demo.mjs",
    "dev:reset": "node scripts/dev/reset-state.mjs",
    "dev:credentials": "node scripts/dev/credentials.mjs",
    "dev:stress": "node scripts/dev/stress-test.mjs",
    "dev:mock-players": "node scripts/dev/mock-players.mjs",
    "dev:tunnel": "node scripts/dev/tunnel.mjs",
    "check": "npm --prefix apps/backend run check",
    "build": "npm -w @spillorama/shared-types run build && npm -w @spillorama/game-client run build && npm -w @spillorama/admin-web run build && npm --prefix apps/backend run build",
    "build:admin": "npm -w @spillorama/admin-web run build",
    "build:types": "npm -w @spillorama/shared-types run build",
    "build:games": "npm -w @spillorama/shared-types run build && npm -w @spillorama/game-client run build",
    "test:compliance": "npm --prefix apps/backend run test:compliance",
    "test:games": "npm -w @spillorama/game-client run test",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:ui": "playwright test --ui",
    "test:pilot-flow": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:pilot-flow:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:pilot-flow:debug": "PWDEBUG=1 playwright test --config=tests/e2e/playwright.config.ts",
    "test:pilot-flow:manual": "playwright test --config=tests/e2e/playwright.config.ts tests/e2e/spill1-manual-flow.spec.ts",
    "test:synthetic": "bash scripts/synthetic/spill1-round-runner.sh",
    "test:synthetic:dry-run": "bash scripts/synthetic/spill1-round-runner.sh --dry-run",
    "test:synthetic:unit": "vitest run scripts/__tests__/synthetic/",
    "diagnose:pilot": "node scripts/diagnose-pilot.mjs",
    "forensics:purchase-open": "bash scripts/purchase-open-forensics.sh",
    "audit:db": "node apps/backend/scripts/audit-db.mjs",
    "build:visual-harness": "npm -w @spillorama/shared-types run build && npm -w @spillorama/game-client run build:visual-harness",
    "serve:visual-harness": "npm -w @spillorama/game-client run serve:visual-harness",
    "check:all": "npm run check && npm run build && npm run test:compliance",
    "docs:check": "node scripts/docs/validate-docs.mjs",
    "deploy:backend": "bash infra/deploy-backend.sh",
    "import:legacy-templates": "npm --prefix apps/backend run import:legacy-templates --",
    "matrix:generate": "tsx scripts/generate-parity-matrix.ts",
    "matrix:check": "tsx scripts/generate-parity-matrix.ts --check",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:no-backdrop-js": "node scripts/stylelint-rules/lint-no-backdrop-js.mjs",
    "lint:no-unsafe-html": "node scripts/stylelint-rules/lint-no-unsafe-html.mjs",
    "lint:blink": "npm run lint:css && npm run lint:no-backdrop-js",
    "lint:xss": "npm run lint:no-unsafe-html",
    "lint:all": "npm run lint:css && npm run lint:no-backdrop-js && npm run lint:no-unsafe-html",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json apps/backend/src apps/admin-web/src packages",
    "lint:arch:baseline": "depcruise --config .dependency-cruiser.cjs --output-type baseline --output-to .dependency-cruiser-known-violations.json apps/backend/src apps/admin-web/src packages",
    "lint:arch:graph": "depcruise --config .dependency-cruiser.cjs --output-type mermaid apps/backend/src apps/admin-web/src packages",
    "test:stylelint": "node --test \"scripts/stylelint-rules/__tests__/*.mjs\"",
    "test:tobias-readiness": "node --test scripts/__tests__/generate-tobias-readiness.test.mjs",
    "test:autonomy": "bash scripts/autonomy-smoke-test.sh",
    "perf:check": "npm --prefix scripts/performance-budget run check",
    "perf:collect": "npm --prefix scripts/performance-budget run collect",
    "perf:compare": "npm --prefix scripts/performance-budget run compare",
    "perf:baseline": "npm --prefix scripts/performance-budget run baseline",
    "pilot-hw:validate": "tsx scripts/pilot-hardware/validate-profile.ts",
    "perf:collect:pilot-hw": "tsx scripts/pilot-hardware/collect-metrics-pilot-hw.ts",
    "perf:compare:pilot-hw": "tsx scripts/pilot-hardware/compare-pilot-hw.ts",
    "perf:check:pilot-hw": "npm run perf:collect:pilot-hw && npm run perf:compare:pilot-hw",
    "test:visual:pilot-hw": "npm -w @spillorama/game-client exec playwright test --project=chromium-pilot-hw",
    "schema:snapshot": "bash scripts/schema-ci/snapshot.sh",
    "schema:diff": "bash scripts/schema-ci/diff-schema.sh",
    "schema:lint": "bash scripts/squawk-check.sh",
    "schema:lint:all": "bash scripts/squawk-check.sh --all",
    "schema:atlas-snapshot": "bash scripts/atlas-snapshot.sh",
    "skills:map": "node scripts/build-skill-file-map.mjs",
    "skills:for-file": "node scripts/find-skills-for-file.mjs",
    "prepare": "husky || true && node scripts/setup-husky.mjs || true"
  },
  "//lint_staged_rationale": "Lint-staged config has been moved to .lintstagedrc.json (2026-05-08). The standalone file makes hook contents self-documenting and lets us add validate-skill-frontmatter, check-markdown-links, validate-migration-name, and check-large-binaries without bloating package.json.",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/pngjs": "^6.0.5",
    "danger": "^13.0.7",
    "dependency-cruiser": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pngjs": "^7.0.0",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "//overrides_rationale": "SEC-P0-003 (Bølge 2A 2026-04-28): targeted security overrides — these are NPM `overrides` entries that force vulnerable transitive deps to patched versions. We use overrides INSTEAD of `npm audit fix` because audit-fix's lockfile re-resolution bumps unrelated dev-deps (notably artillery's plugin chain) into newer @opentelemetry/* + protobufjs that have their own active CVEs. Each override is intentionally scoped to a specific CVE chain. (1) @xmldom/xmldom: pulled via pixi.js → 4 HIGH advisories (GHSA-2v35-w6hq-6mfw DoS + GHSA-f6ww-3ggp-fr8h XML-injection + GHSA-x6wf-f3px-wcqx + GHSA-j759-j44w-7fr8). (2) protobufjs ^8.0.3: GHSA-xq3m-2v4x-88gg arbitrary code exec in 8.0.0; only relevant via the same artillery+otlp chain that audit-fix wants to bump. Pinning to 8.0.3+ patches the CVE without forcing the whole otlp chain. Remove these overrides when upstream pixi.js / artillery resolve transitively. See FIN-P0-03 in docs/audit/SECURITY_AUDIT_2026-04-28.md.",
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "protobufjs": "^8.0.3"
  }
}
