{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "BIN-539: Compliance / finance monitoring. Draw-engine errors (critical for regulator audit) + wallet-operation latency + claim-submit rate as a financial sanity signal. Pages on-call + compliance-eier when any wallet-operation-error-rate row stays red.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Draw-engine errors — by category. TRANSIENT is OK (network/Redis hiccup), LOCK_TIMEOUT sustained is NOT (scheduler lock is stuck). Zero sustained.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "errors / min",
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "cpm"
        }
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum by (category) (rate(bingo_draw_errors_total[5m])) * 60",
          "legendFormat": "{{category}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Draw-engine errors by category (per min)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Stuck-room count. Non-zero = watchdog detected a room where drawing stalled; requires manual investigation (admin force-end).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "bingo_stuck_rooms",
          "legendFormat": "stuck rooms",
          "refId": "A"
        }
      ],
      "title": "Stuck rooms (now)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Wallet-operation latency p95/p99 by operation (transfer/debit/credit/topUp/withdraw). Spikes in transfer p99 ≈ Postgres / wallet-adapter contention — a wallet transfer that stalls means a stake got nobody (or nobody got a prize).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "area" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(bingo_wallet_operation_duration_ms_bucket[5m])))",
          "legendFormat": "{{operation}} p95",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (operation, le) (rate(bingo_wallet_operation_duration_ms_bucket[5m])))",
          "legendFormat": "{{operation}} p99",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Wallet operation latency (ms, by operation)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Claim-submit rate by type (LINE / BINGO / EXTRA_PRIZE). Normally LINE >> BINGO. If BINGO > LINE persistently, either the line check is broken or a single winner is closing the round first. Feeds into daily-report reconciliation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "claims / min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "cpm"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum by (type) (rate(spillorama_claim_submitted_total[5m])) * 60",
          "legendFormat": "{{type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Claim submits by type (per min)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Total payout volume per min, by hall. Sudden volume jump = either a large prize just paid out (normal) or a regression paying out too much (not normal). Reconcile against daily-report in Grafana Explore.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "NOK / min",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyNOK"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum by (hall) (rate(spillorama_payout_amount_sum[5m])) * 60",
          "legendFormat": "{{hall}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Payout volume per hall (NOK / min)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Lock-timeout counter. Zero sustained. Anything above zero ≈ scheduler had to force a lock release — race condition or a crashed worker.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 27 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "increase(bingo_lock_timeouts_total[15m])",
          "legendFormat": "lock timeouts (15m)",
          "refId": "A"
        }
      ],
      "title": "Scheduler lock timeouts (15m rolling)",
      "type": "stat"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["spillorama", "compliance", "BIN-539"],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "DS_PROM",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "1h"]
  },
  "timezone": "Europe/Oslo",
  "title": "Spillorama — Finance gates (BIN-539)",
  "uid": "spillorama-finance-gates",
  "version": 1,
  "weekStart": ""
}
