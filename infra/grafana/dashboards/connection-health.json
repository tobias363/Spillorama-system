{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "BIN-539: Socket health. Reconnect rate + rate-limit rejections + active socket count + draw-gap events. The first page-the-on-call dashboard if a pilot goes sideways.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Reconnect ratio (reconnects per min / active sockets). Alert threshold 2%: above it, something in the network or shared-state layer is flapping.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "axisLabel": "ratio",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true,
            "thresholdsStyle": { "mode": "area" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum(rate(spillorama_reconnect_total[5m])) * 60 / clamp_min(sum(bingo_socket_connections), 1)",
          "legendFormat": "reconnect ratio (5m)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum by (reason) (rate(spillorama_reconnect_total[5m])) * 60 / clamp_min(sum(bingo_socket_connections), 1)",
          "legendFormat": "{{reason}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Reconnect ratio (per 5m, vs active sockets)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Current active Socket.IO connections. Sudden drop = mass disconnect; flat = server-side hang.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "bingo_socket_connections",
          "legendFormat": "sockets",
          "refId": "A"
        }
      ],
      "title": "Active socket connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Reconnect counter split by reason. Useful once the alert fires — tells you whether it's network-side (transport close, ping timeout) or server-side (io server disconnect).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "reconnects / min",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "cpm"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum by (reason) (rate(spillorama_reconnect_total[5m])) * 60",
          "legendFormat": "{{reason}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Reconnects by reason (per min)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Rate-limit rejections per socket event. Elevated numbers → something is hammering the API (bot, retry storm, or a client bug).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "rejections / min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "cpm"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "sum by (event) (rate(bingo_rate_limit_rejections_total[5m])) * 60",
          "legendFormat": "{{event}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Rate-limit rejections by event (per min)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Scheduler tick p95/p99. Above p99 > 500ms → scheduler is behind, draws will be late-to-client.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "area" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 250 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bingo_scheduler_tick_duration_ms_bucket[5m])))",
          "legendFormat": "scheduler p95",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(bingo_scheduler_tick_duration_ms_bucket[5m])))",
          "legendFormat": "scheduler p99",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Scheduler tick p95/p99 (ms)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["spillorama", "pilot", "BIN-539", "alert"],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "DS_PROM",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"]
  },
  "timezone": "Europe/Oslo",
  "title": "Spillorama — Connection health (BIN-539)",
  "uid": "spillorama-connection-health",
  "version": 1,
  "weekStart": ""
}
