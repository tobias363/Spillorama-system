# Husky pre-commit hook
#
# Seks-trinns enforcement (utvidet 2026-05-13 etter bash 3.2-port av FRAGILITY-check):
#   Trinn 1 — PM-gate: blokkerer commit hvis PM-onboarding-gate ikke gyldig
#   Trinn 2 — Tier-A intent: blokkerer commit på Tier-A-paths uten Intent-confirmed-by
#   Trinn 3 — FRAGILITY-check: krever [context-read: F-NN] på FRAGILITY-flagged filer
#   Trinn 4 — COMPREHENSION-check: krever ## Comprehension-blokk når [context-read:] er satt
#   Trinn 5 — Bug-resurrection: krever [resurrection-acknowledged: <grunn>] på recent-fix-linjer
#   Trinn 6 — Lint-staged: kvalitets-sjekker på endrede filer
#
# Lint-staged (.lintstagedrc.json) matcher endrede filer mot:
#  - stylelint --fix paa CSS-filer
#  - lint-no-backdrop-js + lint-no-unsafe-html paa TS-filer
#  - npm run check (TypeScript strict) paa apps/backend/src/**/*.ts
#  - validate-skill-frontmatter paa .claude/skills/*/SKILL.md
#  - check-markdown-links paa docs/**/*.md
#  - validate-migration-name paa apps/backend/migrations/*.sql
#  - check-large-binaries paa store binary-typer
#
# Hvis hook feiler, fiks overtredelsene FOR commit. For nedbypass med
# begrunnelse: commit med --no-verify og dokumenter hvorfor.
#
# Bypass av PM-gate spesifikt:
#   PM_GATE_BYPASS=1 git commit ...
#   git commit -m "fix: subject\n\n[bypass-pm-gate: <begrunnelse>]"
#
# Bypass av Tier-A intent-sjekk:
#   PM_INTENT_BYPASS=1 git commit ...
#
# Bypass av FRAGILITY-sjekk:
#   FRAGILITY_BYPASS=1 git commit ...
#   git commit -m "fix: subject\n\n[bypass-fragility-check: <begrunnelse>]"
#
# Bypass av COMPREHENSION-check:
#   COMPREHENSION_BYPASS=1 git commit ...
#   git commit -m "fix: subject\n\n[comprehension-bypass: <begrunnelse min 20 tegn>]"
#
# Bypass av bug-resurrection-sjekk:
#   RESURRECTION_BYPASS=1 git commit ...
#   git commit -m "fix: subject\n\n[resurrection-acknowledged: <begrunnelse>]"
#
# Se docs/engineering/PRE_COMMIT_HOOKS.md for full liste over regler og
# hvordan legge til nye hooks.

# Trinn 1 — PM-gate enforcement (graceful hvis pm-checkpoint.sh ikke finnes)
node scripts/check-pm-gate.mjs --strict || exit 1

# Trinn 2 — Tier-A intent-håndhevelse
node scripts/check-tier-a-intent.mjs || exit 1

# Trinn 3 — FRAGILITY-check (vanntett FRAGILITY_LOG-enforcement)
# Bash 3.2-kompatibel: wrapperen delegerer til scripts/check-fragility-comprehension.mjs
if [ -x .husky/pre-commit-fragility-check.sh ]; then
  .husky/pre-commit-fragility-check.sh || exit 1
fi

# Trinn 4 — COMPREHENSION-check (krever ## Comprehension-blokk hvis [context-read:] satt)
# Plassert etter FRAGILITY-check fordi den validerer at [context-read:]-markeren
# som FRAGILITY-check krever, er paraphrasert ekte (ikke fluff).
if [ -f ".husky/pre-commit-comprehension.sh" ]; then
  bash .husky/pre-commit-comprehension.sh || exit 1
fi

# Trinn 5 — Bug-resurrection-check (2026-05-13)
# Blokkerer commits som endrer linjer fra recent fix-commits uten å
# eksplisitt acknowledge med [resurrection-acknowledged: <grunn>].
if [ -x .husky/pre-commit-resurrection-check.sh ]; then
  .husky/pre-commit-resurrection-check.sh || exit 1
fi

# Trinn 6 — Lint-staged kvalitets-sjekker
npx lint-staged
