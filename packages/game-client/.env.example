# Game-client environment variables. Copy to `.env.local` (gitignored)
# and fill in the secrets. Only variables prefixed with `VITE_` are
# exposed to the browser bundle by Vite.

# OBS-2 (2026-05-13): game-client Sentry config example.
# Copy this to `.env.local` (gitignored) and fill in real values.
#
# Sentry DSN — same DSN as the backend (Tobias-direktiv 2026-05-13:
# one DSN for both surfaces, split into separate projects later if
# the quota or noise demands it).
# Region: EU (de.sentry.io).
# VITE_SENTRY_DSN=https://<public-key>@o<org-id>.ingest.de.sentry.io/<project-id>
VITE_SENTRY_DSN=

# --- OBS-5: PostHog event-analytics ---
# Write-only client API-key. EU-region by default (eu.posthog.com).
# Safe to ship in client bundles — the token is write-only and cannot
# be used to read data out of PostHog. When unset → analytics disabled.
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
