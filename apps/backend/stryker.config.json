{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker mutation-testing configuration for Spillorama backend. Backend bruker tsx --test (Node's built-in test runner med TAP-output), ikke vitest — derfor tap-runner istedenfor vitest-runner. Se docs/engineering/MUTATION_TESTING.md for rasjonale.",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress", "json"],
  "testRunner": "tap",
  "tap": {
    "testFiles": [
      "src/game/__tests__/MasterActionService.test.ts",
      "src/game/Game1LobbyService.test.ts",
      "src/game/Game1HallReadyService.test.ts",
      "src/game/Game1HallReadyService.hallStatus.test.ts",
      "src/game/Game1HallReadyService.req007.test.ts",
      "src/game/GamePlanRunService.test.ts",
      "src/game/__tests__/GamePlanRunService.goh.test.ts",
      "src/game/__tests__/GamePlanRunService.dateRowToString.test.ts",
      "src/wallet/WalletOutboxWorker.test.ts"
    ],
    "nodeArgs": [
      "--import",
      "tsx/esm",
      "--test-reporter=tap",
      "-r",
      "{{hookFile}}",
      "{{testFile}}"
    ]
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/game/MasterActionService.ts",
    "src/game/Game1LobbyService.ts",
    "src/game/Game1HallReadyService.ts",
    "src/game/GamePlanRunService.ts",
    "src/wallet/WalletOutboxWorker.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "ignorePatterns": [
    "dist",
    "migrations",
    "scripts",
    "node_modules",
    ".stryker-tmp",
    "reports",
    "load-tests",
    "public",
    "tools"
  ],
  "tempDirName": ".stryker-tmp",
  "logLevel": "info"
}
